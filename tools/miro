#!/usr/bin/env bash
#
# miro - unified wrapper command
# Swiss army knife of the MiRo MDK
#
# Provides GUI, simulators, mode switching, IP/name management,
# demo launcher, workspace tools, dashboard, and environment status.
# Colorized output and tab-completion included.

set -euo pipefail

# ----------------------
# Colors
# ----------------------
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
NC="\033[0m"  # No color

# ----------------------
# Pre-flight checks
# ----------------------
: "${MIRO_DIR_MDK:?Environment variable MIRO_DIR_MDK not set}"
: "${MIRO_USER_SETUP:?Environment variable MIRO_USER_SETUP not set}"
: "${MIRO_ROBOT_NAME:?Environment variable MIRO_ROBOT_NAME not set}"
: "${MIRO_NETWORK_MODE:?Environment variable MIRO_NETWORK_MODE not set}"

# ----------------------
# Embedded Bash completion
# ----------------------
_miro_completion() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    local commands="gui mode ip sim ws demo dashboard name status"
    local mode_args="robot sim"
    local sim_args="light full"
    local ws_args="build clean"
    local demo_args="camr caml mics"

    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
    else
        case "${COMP_WORDS[1]}" in
            mode)
                COMPREPLY=( $(compgen -W "$mode_args" -- "$cur") )
                ;;
            sim)
                COMPREPLY=( $(compgen -W "$sim_args" -- "$cur") )
                ;;
            ws)
                COMPREPLY=( $(compgen -W "$ws_args" -- "$cur") )
                ;;
            demo)
                COMPREPLY=( $(compgen -W "$demo_args" -- "$cur") )
                ;;
            *)
                COMPREPLY=()
                ;;
        esac
    fi
}

complete -F _miro_completion miro

# ----------------------
# Helper functions
# ----------------------
confirm() {
    read -rp "$1 [y/N]: " response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

update_conf_line() {
    local VAR="$1"
    local VAL="$2"
    if grep -q "^export $VAR=" "$MIRO_USER_SETUP"; then
        sed -i "s|^export $VAR=.*|export $VAR=$VAL|" "$MIRO_USER_SETUP"
    else
        echo "export $VAR=$VAL" >> "$MIRO_USER_SETUP"
    fi
}

switch_mode() {
    local mode="$1"
    local ip="$2"
    local network_mode="$3"
    update_conf_line "MIRO_NETWORK_MODE" "$network_mode"
    update_conf_line "MIRO_LOCAL_IP" "$ip"
    export MIRO_LOCAL_IP="$ip"
    export MIRO_NETWORK_MODE="$network_mode"
    echo -e "${GREEN}Mode switched to: $mode (MIRO_NETWORK_MODE=$network_mode, MIRO_LOCAL_IP=$ip)${NC}"
}

show_help() {
    cat <<'EOF'
Usage: miro <command> [argument]

Commands:

  gui
      Launch the MiRo GUI client.

  mode {robot|sim}
      Show or switch the current operation mode.
      - No argument displays current mode.
      - robot: static network mode, MIRO_LOCAL_IP = host IP
      - sim: loopback network mode, MIRO_LOCAL_IP = container/internal IP

  ip [update]
      Show the current robot IP. Use 'update' to change it.

  sim [light|full]
      Launch the simulator.
      - Default: full
      - light: lightweight simulator

  ws [build|clean]
      Change directory to the catkin workspace source.
      - Optional arguments: build, clean
      - Default: cd into workspace

  demo [arguments...]
      Launch the base demo script and pass all arguments directly.

  dashboard
      Launch the MiRo dashboard application.

  name [update]
      Show the current robot name. Use 'update' to change it.

  status
      Show a summary of current MiRo environment:
          mode, network mode, local IP, robot IP, robot name
EOF
}

# ----------------------
# Main
# ----------------------
COMMAND="${1:-}"

case "$COMMAND" in

    gui)
        cd "$MIRO_DIR_MDK/bin/shared" && ./client_gui.py
        ;;

    mode)
        MODE_ARG="${2:-}"
        if [[ -z "$MODE_ARG" ]]; then
            echo -e "${YELLOW}Current mode: $MIRO_NETWORK_MODE${NC}"
        elif [[ "$MODE_ARG" == "robot" || "$MODE_ARG" == "sim" ]]; then
            if [[ "$MODE_ARG" == "robot" ]]; then
                HOST_IP=$(ip route get 1 | awk '{print $7; exit}')
                switch_mode "robot" "$HOST_IP" "static"
            else
                CONTAINER_IP=$(hostname -I | tr ' ' '\n' | grep -v '^127\.' | head -n1)
                switch_mode "sim" "$CONTAINER_IP" "loopback"
            fi
        else
            echo -e "${RED}Invalid argument: $MODE_ARG. Valid options: robot, sim${NC}" >&2
            exit 1
        fi
        ;;

    ip)
        if [[ "${2:-}" == "update" ]]; then
            read -rp "Enter new robot IP: " NEW_IP
            export MIRO_ROBOT_IP="$NEW_IP"
            update_conf_line "MIRO_STATIC_IP" "$NEW_IP"
            echo -e "${GREEN}Updated MIRO_ROBOT_IP to $NEW_IP${NC}"
        else
            echo -e "${YELLOW}Current MIRO_ROBOT_IP=$MIRO_ROBOT_IP${NC}"
        fi
        ;;

    sim)
        SIM_ARG="${2:-full}"
        case "$SIM_ARG" in
            light)
                cd "$MIRO_DIR_MDK/sim" && ./launch_sim.sh
                ;;
            full)
                cd "$MIRO_DIR_MDK/sim" && ./launch_full.sh
                ;;
            *)
                echo -e "${RED}Invalid argument: $SIM_ARG. Valid options: light, full${NC}" >&2
                exit 1
                ;;
        esac
        ;;

    ws)
        cd "$MIRO_DIR_MDK/catkin_ws/src"
        WS_ARG="${2:-}"
        case "$WS_ARG" in
            build)
                cd "$MIRO_DIR_MDK/catkin_ws" && catkin build
                ;;
            clean)
                cd "$MIRO_DIR_MDK/catkin_ws" && catkin clean
                ;;
            "")
                ;;  # just cd into workspace
            *)
                echo -e "${RED}Invalid argument: $WS_ARG. Valid options: build, clean${NC}" >&2
                exit 1
                ;;
        esac
        ;;

    demo)
        DEMO_SCRIPT="$MIRO_DIR_SHARE/python/miro2/core/client_demo.py"
        shift
        python3 "$DEMO_SCRIPT" "$@"
        ;;

    dashboard)
        DASHBOARD_APP="$MIRO_DIR_SHARE/python/miro2/dashboard/app.py"
        python3 "$DASHBOARD_APP"
        ;;

    name)
        if [[ "${2:-}" == "update" ]]; then
            read -rp "Enter new robot name: " NEW_NAME
            export MIRO_ROBOT_NAME="$NEW_NAME"
            update_conf_line "MIRO_ROBOT_NAME" "$NEW_NAME"
            echo -e "${GREEN}Updated robot name to $NEW_NAME${NC}"
        else
            echo -e "${YELLOW}Current robot name: $MIRO_ROBOT_NAME${NC}"
        fi
        ;;

    status)
        echo -e "${YELLOW}MiRo Status:${NC}"
        echo -e "  Mode: $MIRO_NETWORK_MODE"
        echo -e "  Local IP: ${MIRO_LOCAL_IP:-unknown}"
        echo -e "  Robot IP: $MIRO_ROBOT_IP"
        echo -e "  Robot Name: $MIRO_ROBOT_NAME"
        ;;

    ""|-h|--help)
        show_help
        ;;

    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}" >&2
        show_help
        exit 1
        ;;
esac
