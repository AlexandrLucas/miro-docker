# Image and container info
IMAGE_NAME=alexandrlucas/miro-docker
CONTAINER_NAME=miro-docker

# User and runtime paths
USER_UID=1000
USER_GID=1000
XDG_RUNTIME_DIR=/run/user/${USER_UID}

# X11 display and auth
DISPLAY=${DISPLAY}
XAUTH=/tmp/.docker.xauth
X11UNIX=/tmp/.X11-unix

# PulseAudio setup
PULSE_SERVER=unix:${XDG_RUNTIME_DIR}/pulse/native
PULSE_SOCKET=${XDG_RUNTIME_DIR}/pulse/native
PULSE_COOKIE_PATH=${HOME}/.config/pulse/cookie
